{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SAZO Design System",
  "colors": {
    "primary": "#EB4666",
    "light": "#222222",
    "dark": "#EB4666"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "Pretendard Variable",
      "source": "https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/woff2/PretendardVariable.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Pretendard Variable",
      "source": "https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/woff2/PretendardVariable.woff2",
      "format": "woff2"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Design System",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "design-system/index"
            ]
          },
          {
            "group": "Foundations",
            "pages": [
              "design-system/원칙/디자인-원칙",
              "design-system/원칙/색상",
              "design-system/원칙/타이포그래피",
              "design-system/원칙/간격",
              "design-system/원칙/모서리-둥글기",
              "design-system/원칙/그림자",
              "design-system/원칙/모션",
              "design-system/원칙/그라디언트",
              "design-system/원칙/아이코노그래피"
            ]
          },
          {
            "group": "Guidelines",
            "pages": [
              "design-system/가이드/디자인-암묵지",
              "design-system/가이드/텍스트-계층",
              "design-system/가이드/간격-리듬",
              "design-system/가이드/버튼-위계",
